# Recreatable scratch. Keep the directory contract, ignore its contents.
/tmp/*
!/tmp/README.md

# Child-repository worktrees are linked through Git, not tracked by this root.
/worktrees/prs/*
!/worktrees/prs/README.md
/worktrees/spikes/*
!/worktrees/spikes/README.md

# Canonical child checkouts. Add concrete names before cloning.
# /example-repo/
# /example-repo-main/

# Secrets and credentials.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
credentials/

# Machine-only runtime state.
/browser/
/browser-profile/
/cache/
/caches/
/profiles/
/sessions/
/sqlite/
/threads/
/log/
/logs/
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.db
*.db-shm
*.db-wal
*.log

# Build and tool caches.
**/__pycache__/
**/.venv/
**/node_modules/
**/.pytest_cache/
**/.cache/
**/.DS_Store

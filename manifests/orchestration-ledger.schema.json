{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariobarin.com/compass/orchestration-ledger.schema.json",
  "title": "Compass principal-authored orchestration ledger",
  "description": "A local mechanical index for principal-authored goals, control documents, verified evidence, and recovery gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "goals"
  ],
  "properties": {
    "schema_version": {
      "const": 5
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/goal"
      }
    }
  },
  "$defs": {
    "nonemptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableNonemptyString": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonemptyString"
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "goal",
        "anchors",
        "control_documents",
        "phase",
        "execution_owner",
        "worker_id",
        "state",
        "next_action",
        "next_check_at",
        "evidence",
        "public_mutation_gate",
        "public_mutation_action",
        "decision_needed",
        "control_writer",
        "control_revision",
        "recovery_circuits",
        "created_at",
        "updated_at",
        "last_verified_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "goal": {
          "$ref": "#/$defs/nonemptyString"
        },
        "anchors": {
          "$ref": "#/$defs/stringList"
        },
        "control_documents": {
          "$ref": "#/$defs/stringList"
        },
        "phase": {
          "enum": [
            "planning",
            "implementation"
          ]
        },
        "execution_owner": {
          "$ref": "#/$defs/nonemptyString"
        },
        "worker_id": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "state": {
          "enum": [
            "planned",
            "active",
            "waiting",
            "blocked",
            "complete",
            "cancelled"
          ]
        },
        "next_action": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "next_check_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "public_mutation_gate": {
          "enum": [
            "closed",
            "authorized",
            "in_flight",
            "complete"
          ]
        },
        "public_mutation_action": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "decision_needed": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/decision"
            }
          ]
        },
        "control_writer": {
          "$ref": "#/$defs/nonemptyString"
        },
        "control_revision": {
          "type": "integer",
          "minimum": 1
        },
        "recovery_circuits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recoveryCircuit"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_verified_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "complete"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "evidence": {
                "minItems": 1
              },
              "next_action": {
                "const": null
              },
              "decision_needed": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "public_mutation_gate": {
                "const": "closed"
              }
            },
            "required": [
              "public_mutation_gate"
            ]
          },
          "then": {
            "properties": {
              "public_mutation_action": {
                "const": null
              }
            }
          },
          "else": {
            "properties": {
              "public_mutation_action": {
                "$ref": "#/$defs/nonemptyString"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "cancelled"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "worker_id": {
                "const": null
              },
              "next_action": {
                "const": null
              },
              "next_check_at": {
                "const": null
              },
              "decision_needed": {
                "const": null
              },
              "public_mutation_gate": {
                "enum": [
                  "closed",
                  "complete"
                ]
              },
              "recovery_circuits": {
                "items": {
                  "allOf": [
                    {
                      "$ref": "#/$defs/recoveryCircuit"
                    },
                    {
                      "properties": {
                        "state": {
                          "not": {
                            "const": "active"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "summary",
        "locator",
        "producer",
        "observed_at",
        "verified_by",
        "recorded_at"
      ],
      "properties": {
        "kind": {
          "enum": [
            "test",
            "artifact",
            "review",
            "runtime",
            "decision",
            "other"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonemptyString"
        },
        "locator": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "producer": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "verified_by": {
          "$ref": "#/$defs/nonemptyString"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "options",
        "prepared_at"
      ],
      "properties": {
        "question": {
          "$ref": "#/$defs/nonemptyString"
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonemptyString"
          }
        },
        "prepared_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "recoveryCircuit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slice_label",
        "state",
        "assigned_worker",
        "last_failure_evidence",
        "last_failure_at",
        "last_reset_evidence",
        "last_reset_at"
      ],
      "properties": {
        "slice_label": {
          "$ref": "#/$defs/nonemptyString"
        },
        "state": {
          "enum": [
            "closed",
            "active",
            "open"
          ]
        },
        "assigned_worker": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "last_failure_evidence": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "last_failure_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_reset_evidence": {
          "$ref": "#/$defs/nullableNonemptyString"
        },
        "last_reset_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "active"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "assigned_worker": {
                "$ref": "#/$defs/nonemptyString"
              }
            }
          },
          "else": {
            "properties": {
              "assigned_worker": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "last_failure_evidence": {
                "type": "string"
              }
            },
            "required": [
              "last_failure_evidence"
            ]
          },
          "then": {
            "properties": {
              "last_failure_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "else": {
            "properties": {
              "last_failure_at": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "last_reset_evidence": {
                "type": "string"
              }
            },
            "required": [
              "last_reset_evidence"
            ]
          },
          "then": {
            "properties": {
              "last_reset_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "else": {
            "properties": {
              "last_reset_at": {
                "const": null
              }
            }
          }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariobarin.com/compass/orchestration-ledger.schema.json",
  "title": "Compass orchestration ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "goals"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/goal"
      }
    }
  },
  "$defs": {
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "goal",
        "execution_owner",
        "worker_id",
        "state",
        "next_action",
        "next_check_at",
        "completion_evidence",
        "public_mutation_gate",
        "public_mutation_action",
        "decision_needed",
        "control_writer",
        "control_revision",
        "control_edit_grants",
        "recovery_circuits",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "execution_owner": {
          "type": "string",
          "minLength": 1
        },
        "worker_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "state": {
          "enum": [
            "planned",
            "active",
            "waiting",
            "blocked",
            "complete",
            "cancelled"
          ]
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "next_check_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completion_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "public_mutation_gate": {
          "enum": [
            "closed",
            "authorized",
            "in_flight",
            "complete"
          ]
        },
        "public_mutation_action": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "decision_needed": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/decision"
            }
          ]
        },
        "control_writer": {
          "type": "string",
          "minLength": 1
        },
        "control_revision": {
          "type": "integer",
          "minimum": 1
        },
        "control_edit_grants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/controlEditGrant"
          }
        },
        "recovery_circuits": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/recoveryCircuit"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "summary",
        "locator",
        "recorded_at"
      ],
      "properties": {
        "kind": {
          "enum": [
            "test",
            "artifact",
            "review",
            "runtime",
            "decision",
            "other"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "options",
        "prepared_at"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prepared_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "controlEditGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "mutations"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "mutations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "set-owner",
              "set-state",
              "set-next",
              "add-evidence",
              "set-gate",
              "set-decision",
              "clear-decision",
              "claim-successor",
              "record-successor-failure",
              "record-successor-success"
            ]
          }
        }
      }
    },
    "recoveryCircuit": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "consecutive_successor_failures": {
                "minimum": 2
              }
            }
          },
          "then": {
            "properties": {
              "state": {
                "const": "open"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "claimed"
              }
            }
          },
          "then": {
            "properties": {
              "consecutive_successor_failures": {
                "maximum": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "closed",
                  "open"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "claimed_by": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "claimed"
              }
            }
          },
          "then": {
            "properties": {
              "claimed_by": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "required": [
        "slice_label",
        "consecutive_successor_failures",
        "state",
        "last_reset_evidence",
        "last_reset_at",
        "claimed_by"
      ],
      "properties": {
        "slice_label": {
          "type": "string",
          "minLength": 1
        },
        "consecutive_successor_failures": {
          "type": "integer",
          "minimum": 0
        },
        "state": {
          "enum": [
            "open",
            "claimed",
            "closed"
          ]
        },
        "last_reset_evidence": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "last_reset_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "claimed_by": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}

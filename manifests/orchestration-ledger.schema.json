{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariobarin.com/compass/orchestration-ledger.schema.json",
  "title": "Compass orchestration ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "goals"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/goal"
      }
    }
  },
  "$defs": {
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "goal",
        "execution_owner",
        "worker_id",
        "state",
        "next_action",
        "next_check_at",
        "completion_evidence",
        "public_mutation_gate",
        "public_mutation_action",
        "decision_needed",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "execution_owner": {
          "type": "string",
          "minLength": 1
        },
        "worker_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "state": {
          "enum": [
            "planned",
            "active",
            "waiting",
            "blocked",
            "complete",
            "cancelled"
          ]
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "next_check_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completion_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "public_mutation_gate": {
          "enum": [
            "closed",
            "authorized",
            "in_flight",
            "complete"
          ]
        },
        "public_mutation_action": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "decision_needed": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/decision"
            }
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "summary",
        "locator",
        "recorded_at"
      ],
      "properties": {
        "kind": {
          "enum": [
            "test",
            "artifact",
            "review",
            "runtime",
            "decision",
            "other"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "options",
        "prepared_at"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prepared_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
